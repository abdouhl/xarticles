---
import Layout from "../layouts/Layout.astro";
import BreadcrumbSchema from "../components/schema/BreadcrumbSchema.astro";
const breadcrumbs = [
    { name: "Home", url: "https://xarticl.es" },
    { name: "Privacy Policy", url: "https://xarticl.es/privacy" },
];
---

<Layout
    site="Xarticl.es"
    title="Privacy Policy"
    tagline="How we collect, use, and protect your information"
    pageTitle="Privacy Policy"
    pageDescription="Read the Xarticl.es Privacy Policy to understand how we handle your data, use cookies, and protect your privacy when you browse our curated long-form articles directory."
    canonicalUrl="https://xarticl.es/privacy"
    ogTitle="Privacy Policy — Xarticl.es"
    ogDescription="Read the Xarticl.es Privacy Policy to understand how we handle your data, use cookies, and protect your privacy."
    ogType="website"
    ogUrl="https://xarticl.es/privacy"
    ogSiteName="Xarticl.es"
>
    <BreadcrumbSchema items={breadcrumbs} />

    <main id="main-content" class="container">
        <div class="legal-content-wrapper">
            <header class="legal-header">
                <h1 class="nu-c-h5 nu-u-text--primary">Privacy Policy</h1>
                <p class="last-updated">Last Updated: January 4, 2026</p>
            </header>

            <article class="nu-u-text--secondary" itemscope itemtype="https://schema.org/WebPage">
                <p class="nu-c-fs-regular">
                    At <strong class="nu-u-text--primary">Xarticl.es</strong>, accessible from
                    <a href="https://xarticl.es" class="nu-u-link--subtle">https://xarticl.es</a>,
                    your privacy is a priority. This Privacy Policy explains what information we
                    collect, how we use it, and your rights as a visitor to our curated directory
                    of the best long-form articles on X (formerly Twitter).
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">1. Information We Collect</h2>
                <p>
                    Xarticl.es is a static website. We do not require account registration
                    and do not directly collect personally identifiable information (PII).
                    The only data we process comes from:
                </p>
                <ul>
                    <li><strong class="nu-u-text--primary">Analytics data</strong> — anonymized usage statistics via Google Analytics (pages viewed, session duration, browser type, general location).</li>
                    <li><strong class="nu-u-text--primary">Local storage</strong> — article IDs you bookmark, stored only in your browser.</li>
                    <li><strong class="nu-u-text--primary">Contact data</strong> — only if you reach out via social media or GitHub.</li>
                </ul>

                <h2 class="nu-c-h6 nu-u-text--primary">2. Local Storage & Bookmarks</h2>
                <p>
                    Our "Saved Articles" feature uses your browser's <strong class="nu-u-text--primary">localStorage</strong>
                    to remember articles you bookmark. This data lives entirely on your device
                    and is never transmitted to our servers. You can clear it anytime by
                    clearing your browser data or clicking "Remove" in the UI.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">3. Google Analytics</h2>
                <p>
                    We use Google Analytics to understand how visitors interact with Xarticl.es.
                    Google Analytics collects anonymized data such as pages visited, time on site,
                    and referring sources. This data helps us improve the directory. No personally
                    identifiable data is shared with us. You may opt out by installing the
                    <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener noreferrer" class="nu-u-link--subtle">Google Analytics Opt-out Browser Add-on</a>.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">4. Cookies</h2>
                <p>
                    We use cookies to optimize your browsing experience, remember preferences,
                    and analyze traffic. Cookies are small text files stored by your browser.
                    Third-party services like Google Analytics also set their own cookies.
                    For full details on managing cookies, see our
                    <a href="/cookies" class="nu-u-link--subtle">Cookie Policy</a>.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">5. Advertising</h2>
                <p>
                    Xarticl.es may display ads through Google AdSense or similar networks
                    to help sustain the project. These networks may use cookies to show you
                    relevant ads based on your browsing history. You can manage ad
                    personalization in your
                    <a href="https://adssettings.google.com" target="_blank" rel="noopener noreferrer" class="nu-u-link--subtle">Google Ad Settings</a>.
                    We do not sell your personal data to advertisers.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">6. Third-Party Links</h2>
                <p>
                    Our directory links to external articles and websites. We are not
                    responsible for the privacy practices or content of those third-party
                    sites. We encourage you to review their privacy policies before
                    providing any personal information.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">7. Children's Privacy</h2>
                <p>
                    Xarticl.es does not knowingly collect personal information from
                    children under 13. If you believe a child has submitted personal
                    information, please contact us so we can remove it.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">8. Your Rights</h2>
                <p>
                    Depending on your location, you may have rights under GDPR, CCPA,
                    or other regulations, including the right to access, correct, or
                    delete your data. Since we collect minimal data, the primary action
                    available is clearing your browser's localStorage. For other requests,
                    contact us below.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">9. Changes to This Policy</h2>
                <p>
                    We may update this Privacy Policy periodically. Changes will be
                    reflected with an updated "Last Updated" date at the top of this page.
                    Continued use of Xarticl.es after changes constitutes acceptance.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">10. Contact Us</h2>
                <p>
                    Questions about our privacy practices? Reach out to
                    <a href="https://twitter.com/abdou_hll" target="_blank" rel="noopener noreferrer" class="nu-u-link--subtle">@abdou_hll</a>
                    on social media or via our
                    <a href="https://github.com/" target="_blank" rel="noopener noreferrer" class="nu-u-link--subtle">GitHub repository</a>.
                </p>
            </article>
        </div>
    </main>
</Layout>