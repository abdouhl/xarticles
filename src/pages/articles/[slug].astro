---
import Layout from "../../layouts/Layout.astro";
import slugMap from "../../data/slug-map.json";
import SoftwareApplicationSchema from "../../components/schema/SoftwareApplicationSchema.astro";
import BreadcrumbSchema from "../../components/schema/BreadcrumbSchema.astro";
import BookmarkButton from "../../components/BookmarkButton";

export async function getStaticPaths() {
  const slugMapData = await import("../../data/slug-map.json");
  const paths = Object.keys(slugMapData.default).map((slug) => ({
    params: { slug },
  }));
  return paths;
}

export const prerender = true;

const { slug } = Astro.params;

const categoryList = (slugMap as Record<string, string[]>)[slug as string];
const categoryName = categoryList?.[0];

if (!categoryName) {
  throw new Error(`Article not found: ${slug}`);
}

const categoryTools = await import(`../../data/articles/${categoryName}.json`);
const found = categoryTools.default.find((x: any) => x.slug === slug) || null;

if (!found) {
  throw new Error(`Article not found: ${slug}`);
}

const tool = found;
const category = categoryName;

const formatDate = (dateStr: string) => {
  try {
    return new Date(dateStr).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });
  } catch {
    return dateStr;
  }
};

const formattedDate = formatDate(tool.created_at);
const canonicalUrl = `https://xarticl.es/articles/${tool.slug}`;
const faviconUrl = `/favicons/${slug}.png`;
const fallbackPath = category === "all" ? "/" : `/${category}`;
const tweetUrl = `https://x.com/${tool.screen_name}/status/${tool.id_str}`;

let meta: any = {};
try {
  const toolMetadata = await import(`../../data/article-metadata/${slug}.json`);
  meta = toolMetadata.default;
} catch (e) {}

const seoTitle = meta.title || tool.title;
const seoDescription = meta.description || tool.body;
const seoOgImage = tool.original_img_url;
const seoOgType = "article";
const seoOgSiteName = "Xarticl.es";

const encodedShareText = encodeURIComponent(
  `Check out ${tool.title} - a great article I found on Xarticl.es!`
);
const encodedCanonicalUrl = encodeURIComponent(canonicalUrl);
const xShareUrl = `https://x.com/intent/post?text=${encodedShareText}&url=${encodedCanonicalUrl}&via=${tool.screen_name}`;
const linkedinShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedCanonicalUrl}`;
const redditShareUrl = `https://www.reddit.com/submit?url=${encodedCanonicalUrl}&title=${encodedShareText}`;

const allCategoryTools = categoryTools.default || [];
const otherTools = allCategoryTools.filter((t: any) => t.slug !== slug);
const relatedTools = otherTools.sort(() => Math.random() - 0.5).slice(0, 3);

const categoryTitle = category.charAt(0).toUpperCase() + category.slice(1);
const breadcrumbs = [
  { name: "Home", url: "https://xarticl.es" },
  { name: categoryTitle, url: `https://xarticl.es/${category}` },
  { name: tool.title },
];

const tldr: string | undefined = tool.tldr;
const whyThisMatters: string | undefined = tool.whyThisMatters;
const whoShouldRead: string | undefined = tool.whoShouldRead;
---

<Layout
  site={`Xarticl.es - ${tool.title}`}
  title={seoTitle}
  tagline={seoDescription}
  pageTitle={seoTitle}
  pageDescription={seoDescription}
  canonicalUrl={canonicalUrl}
  ogTitle={seoTitle}
  ogDescription={seoDescription}
  ogUrl={canonicalUrl}
  ogImage={seoOgImage}
  ogType={seoOgType}
  ogSiteName={seoOgSiteName}
  twitterCard="summary_large_image"
  twitterTitle={seoTitle}
  twitterDescription={seoDescription}
  twitterImage={seoOgImage}
  pageFavicon={faviconUrl}
>
  <SoftwareApplicationSchema
    name={tool.title}
    description={tool.body}
    url={tool.url}
    tag={tool.tag}
    dateAdded={tool.created_at}
    category={category}
  />
  <BreadcrumbSchema items={breadcrumbs} />

  <main id="main-content" class="article-page">

    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <a href={`/${category}`}>{categoryTitle}</a>
      <span aria-hidden="true">›</span>
      <span>{tool.title}</span>
    </nav>

    <div class="article-layout">

      <!-- LEFT: Main article card -->
      <article class="article-card" itemscope itemtype="https://schema.org/Article">

        <!-- Cover image -->
        <div class="article-cover">
          <img
            src={tool.original_img_url}
            alt={tool.title}
            class="article-cover-img"
            itemprop="image"
            loading="eager"
          />
          <div class="article-cover-tags">
            <a href={`/${category}`} class="cover-tag">{categoryTitle}</a>
            {tool.screen_name && (
              <span class="cover-tag">@{tool.screen_name}</span>
            )}
          </div>
        </div>

        <!-- Article body -->
        <div class="article-body">

          <header class="article-header">
            <h1 class="article-title" itemprop="headline">{tool.title}</h1>
            <div class="article-meta">
              <time datetime={tool.created_at} itemprop="datePublished">{formattedDate}</time>
              {tool.screen_name && (
                <>
                  <span class="meta-dot">·</span>
                  <a
                    href={`https://x.com/${tool.screen_name}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="meta-author"
                    itemprop="author"
                  >
                    @{tool.screen_name}
                  </a>
                </>
              )}
            </div>
          </header>

          <!-- About section -->
          <section class="article-about" aria-label="About this article">
            {tool.body && (
              <p class="article-summary" itemprop="description">{tool.body}</p>
            )}
            {meta.description && meta.description !== tool.body && (
              <p class="article-description">{meta.description}</p>
            )}
          </section>

          <!-- Core Structure — renders only when fields are present -->
          {(tldr || whyThisMatters || whoShouldRead) && (
            <div class="core-sections">

              {tldr && (
                <div class="core-section">
                  <p class="core-label">
                    <span class="core-emoji">⚡</span> TL;DR
                  </p>
                  <p class="core-body">{tldr}</p>
                </div>
              )}

              {whyThisMatters && (
                <div class="core-section">
                  <p class="core-label">
                    <span class="core-emoji">🎯</span> Why this matters
                  </p>
                  <p class="core-body">{whyThisMatters}</p>
                </div>
              )}

              {whoShouldRead && (
                <div class="core-section">
                  <p class="core-label">
                    <span class="core-emoji">👥</span> Who should read this
                  </p>
                  <p class="core-body">{whoShouldRead}</p>
                </div>
              )}

            </div>
          )}

          <!-- CTA -->
          <div class="article-cta">
            {tool.id_str ? (
              <a
                href={tweetUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-read"
                itemprop="url"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 256 256">
                  <path d="M214.75,211.71l-62.6-98.38,61.77-67.95a8,8,0,0,0-11.84-10.76L143.24,99.34,102.75,35.71A8,8,0,0,0,96,32H48a8,8,0,0,0-6.75,12.3l62.6,98.37-61.77,68a8,8,0,1,0,11.84,10.76l58.84-64.72,40.49,63.63A8,8,0,0,0,160,224h48a8,8,0,0,0,6.75-12.29ZM164.39,208,62.57,48h29L193.43,208Z"/>
                </svg>
                Read on X
              </a>
            ) : (
              <span class="btn-read btn-disabled">No link available</span>
            )}
            <BookmarkButton client:load slug={slug} title={tool.title} variant="default" />
          </div>

          <!-- Share -->
          <div class="article-share">
            <span class="share-label">Share</span>
            <div class="share-buttons">
              <a href={xShareUrl} target="_blank" rel="noopener noreferrer" class="share-btn" title="Share on X" aria-label="Share on X">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 256 256">
                  <path d="M214.75,211.71l-62.6-98.38,61.77-67.95a8,8,0,0,0-11.84-10.76L143.24,99.34,102.75,35.71A8,8,0,0,0,96,32H48a8,8,0,0,0-6.75,12.3l62.6,98.37-61.77,68a8,8,0,1,0,11.84,10.76l58.84-64.72,40.49,63.63A8,8,0,0,0,160,224h48a8,8,0,0,0,6.75-12.29ZM164.39,208,62.57,48h29L193.43,208Z"/>
                </svg>
              </a>
              <a href={linkedinShareUrl} target="_blank" rel="noopener noreferrer" class="share-btn" title="Share on LinkedIn" aria-label="Share on LinkedIn">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 256 256">
                  <path d="M216,24H40A16,16,0,0,0,24,40V216a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V40A16,16,0,0,0,216,24Zm0,192H40V40H216V216ZM96,112v64a8,8,0,0,1-16,0V112a8,8,0,0,1,16,0Zm88,28v36a8,8,0,0,1-16,0V140a20,20,0,0,0-40,0v36a8,8,0,0,1-16,0V112a8,8,0,0,1,15.79-1.78A36,36,0,0,1,184,140ZM100,84A12,12,0,1,1,88,72,12,12,0,0,1,100,84Z"/>
                </svg>
              </a>
              <a href={redditShareUrl} target="_blank" rel="noopener noreferrer" class="share-btn" title="Share on Reddit" aria-label="Share on Reddit">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 256 256">
                  <path d="M248,104a32,32,0,0,0-52.94-24.19c-16.75-8.9-36.76-14.28-57.66-15.53l5.19-31.17,17.72,2.72a24,24,0,1,0,2.87-15.74l-26-4a8,8,0,0,0-9.11,6.59L121.2,64.16c-21.84.94-42.82,6.38-60.26,15.65a32,32,0,0,0-42.59,47.74A59,59,0,0,0,16,144c0,21.93,12,42.35,33.91,57.49C70.88,216,98.61,224,128,224s57.12-8,78.09-22.51C228,186.35,240,165.93,240,144a59,59,0,0,0-2.35-16.45A32.16,32.16,0,0,0,248,104ZM184,24a8,8,0,1,1-8,8A8,8,0,0,1,184,24Zm40.13,93.78a8,8,0,0,0-3.29,10A43.58,43.58,0,0,1,224,144c0,16.53-9.59,32.27-27,44.33C178.67,201,154.17,208,128,208s-50.67-7-69-19.67C41.59,176.27,32,160.53,32,144a43.75,43.75,0,0,1,3.14-16.17,8,8,0,0,0-3.27-10A16,16,0,1,1,52.94,94.59a8,8,0,0,0,10.45,2.23l.36-.22C81.45,85.9,104.25,80,128,80h0c23.73,0,46.53,5.9,64.23,16.6l.42.25a8,8,0,0,0,10.39-2.26,16,16,0,1,1,21.07,23.19ZM88,144a16,16,0,1,1,16-16A16,16,0,0,1,88,144Zm96-16a16,16,0,1,1-16-16A16,16,0,0,1,184,128Zm-16.93,44.25a8,8,0,0,1-3.32,10.82,76.18,76.18,0,0,1-71.5,0,8,8,0,1,1,7.5-14.14,60.18,60.18,0,0,0,56.5,0A8,8,0,0,1,167.07,172.25Z"/>
                </svg>
              </a>
              <button class="share-btn" id="copyLinkBtn" title="Copy link" aria-label="Copy link to clipboard">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 256 256">
                  <path d="M240,88.23a54.43,54.43,0,0,1-16,37L189.25,160a54.27,54.27,0,0,1-38.63,16h-.05A54.63,54.63,0,0,1,96,119.84a8,8,0,0,1,16,.45A38.62,38.62,0,0,0,150.58,160h0a38.39,38.39,0,0,0,27.31-11.31l34.75-34.75a38.63,38.63,0,0,0-54.63-54.63l-11,11A8,8,0,0,1,135.7,59l11-11A54.65,54.65,0,0,1,224,48,54.86,54.86,0,0,1,240,88.23ZM109,185.66l-11,11A38.41,38.41,0,0,1,70.6,208h0a38.63,38.63,0,0,1-27.29-65.94L78,107.31A38.63,38.63,0,0,1,144,135.71a8,8,0,0,0,16,.45A54.86,54.86,0,0,0,144,96a54.65,54.65,0,0,0-77.27,0L32,130.75A54.62,54.62,0,0,0,70.56,224h0a54.28,54.28,0,0,0,38.64-16l11-11A8,8,0,0,0,109,185.66Z"/>
                </svg>
              </button>
            </div>
          </div>

        </div>
      </article>

      <!-- RIGHT: Sidebar -->
      <aside class="article-sidebar">

        <!-- Author card -->
        <div class="sidebar-card">
          <p class="sidebar-label">Author</p>
          <div class="author-row">
            <img
              src={`https://unavatar.io/twitter/${tool.screen_name}`}
              alt={`@${tool.screen_name}`}
              class="author-avatar"
              onerror="this.src='/favicons/default.png'"
              loading="lazy"
            />
            <div>
              <a
                href={`https://x.com/${tool.screen_name}`}
                target="_blank"
                rel="noopener noreferrer"
                class="author-handle"
              >
                @{tool.screen_name}
              </a>
              <p class="author-sub">View on X</p>
            </div>
          </div>
        </div>

        <!-- Details card -->
        <div class="sidebar-card">
          <p class="sidebar-label">Details</p>
          <dl class="detail-list">
            <div class="detail-row">
              <dt>Category</dt>
              <dd><a href={`/${category}`} class="detail-link">{categoryTitle}</a></dd>
            </div>
            <div class="detail-row">
              <dt>Published</dt>
              <dd>{formattedDate}</dd>
            </div>
            {tool.tag && (
              <div class="detail-row">
                <dt>Tag</dt>
                <dd>{tool.tag}</dd>
              </div>
            )}
          </dl>
        </div>

        <!-- AdSense slot — shows Binance banner when no ad is served -->
        <div class="adsense-slot" aria-label="Advertisement">
          <a
            href="https://www.binance.com/register?ref=BMNSQVZ9"
            target="_blank"
            rel="noopener noreferrer sponsored"
            class="binance-banner-link"
            aria-label="Explore Crypto on Binance"
          >
            <img
              src="/binance-2.png"
              alt="Explore Crypto with me on Binance"
              class="binance-banner binance-banner--desktop"
              loading="lazy"
            />
            <img
              src="/binance-3.png"
              alt="Explore Crypto with me on Binance"
              class="binance-banner binance-banner--mobile"
              loading="lazy"
            />
          </a>
        </div>

      </aside>
    </div>

    <!-- Related articles -->
    {relatedTools.length > 0 && (
      <section class="related-section" aria-label="Related articles">
        <h2 class="related-heading">More in {categoryTitle}</h2>
        <div class="related-grid">
          {relatedTools.map((t: any) => (
            <a href={`/articles/${t.slug}`} class="related-card">
              <div class="related-cover">
                <img
                  src={t.original_img_url || `/favicons/${t.slug}.png`}
                  alt={t.title}
                  class="related-img"
                  loading="lazy"
                  onerror="this.src='/favicons/default.png'"
                />
                <span class="related-tag">{categoryTitle}</span>
              </div>
              <div class="related-body">
                <strong class="related-title">{t.title}</strong>
                {t.screen_name && (
                  <span class="related-author">@{t.screen_name}</span>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="page-nav">
      <a href={fallbackPath} class="back-link">← Back to {categoryTitle}</a>
    </div>

  </main>

  <script type="module">
    const copyBtn = document.getElementById("copyLinkBtn");
    if (copyBtn) {
      copyBtn.addEventListener("click", () => {
        navigator.clipboard.writeText(window.location.href).then(() => {
          const original = copyBtn.innerHTML;
          copyBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>';
          setTimeout(() => (copyBtn.innerHTML = original), 2000);
        });
      });
    }
  </script>

  <style>
    /* ── Page shell ───────────────────────────────────── */
    .article-page {
      max-width: 1100px;
      margin: 0 auto;
      padding: var(--spacing-06) var(--spacing-05) var(--spacing-10);
    }

    /* ── Breadcrumb ───────────────────────────────────── */
    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: var(--desktop-caption);
      font-family: var(--monospace);
      color: var(--content-secondary);
      margin-bottom: var(--spacing-06);
      flex-wrap: wrap;
    }
    .breadcrumb a {
      color: var(--content-secondary);
      text-decoration: none;
    }
    .breadcrumb a:hover { color: var(--content-primary); }
    .breadcrumb span:last-child {
      color: var(--content-primary);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      max-width: 260px;
    }

    /* ── Two-column layout ────────────────────────────── */
    .article-layout {
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: var(--spacing-07);
      align-items: start;
    }
    @media (max-width: 768px) {
      .article-layout { grid-template-columns: 1fr; }
    }

    /* ── Article card ─────────────────────────────────── */
    .article-card {
      background: #111111;
      border-radius: 12px;
      overflow: hidden;
      box-shadow:
        0 0 0 0.5px rgba(255,255,255,0.08),
        0 4px 24px rgba(0,0,0,0.4);
    }

    /* Cover */
    .article-cover {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 7;
      background: #1a1a1a;
      overflow: hidden;
    }
    .article-cover-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .article-cover-tags {
      position: absolute;
      bottom: 12px;
      left: 12px;
      display: flex;
      gap: 6px;
    }
    .cover-tag {
      background: rgba(0,0,0,0.62);
      color: #fff;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border: 0.5px solid rgba(255,255,255,0.12);
      padding: 3px 9px;
      border-radius: 4px;
      font-family: var(--monospace);
      font-size: 11px;
      line-height: 1.5;
      text-decoration: none;
    }
    .cover-tag:hover { background: rgba(0,0,0,0.85); }

    /* Body */
    .article-body {
      padding: var(--spacing-07);
      display: flex;
      flex-direction: column;
      gap: var(--spacing-06);
    }
    @media (max-width: 600px) {
      .article-body { padding: var(--spacing-05); }
    }

    /* Header */
    .article-header { display: flex; flex-direction: column; gap: var(--spacing-02); }
    .article-title {
      margin: 0;
      font-size: clamp(1.25rem, 3vw, 1.75rem);
      font-weight: 700;
      color: #f0f0f0;
      line-height: 1.25;
    }
    .article-meta {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: var(--desktop-caption);
      font-family: var(--monospace);
      color: rgba(255,255,255,0.4);
    }
    .meta-dot { opacity: 0.4; }
    .meta-author {
      color: rgba(255,255,255,0.5);
      text-decoration: none;
    }
    .meta-author:hover { color: #fff; }

    /* About */
    .article-about { display: flex; flex-direction: column; gap: var(--spacing-03); }
    .article-summary {
      margin: 0;
      font-size: var(--desktop-body);
      line-height: 1.7;
      color: #d0d0d0;
    }
    .article-description {
      margin: 0;
      font-size: var(--desktop-body-sm);
      line-height: 1.7;
      color: rgba(255,255,255,0.5);
    }

    /* ── Core Structure ───────────────────────────────── */
    .core-sections {
      display: flex;
      flex-direction: column;
      border: 0.5px solid rgba(255,255,255,0.08);
      border-radius: 8px;
      overflow: hidden;
    }
    .core-section {
      padding: var(--spacing-05);
      border-bottom: 0.5px solid rgba(255,255,255,0.08);
    }
    .core-section:last-child {
      border-bottom: none;
    }
    .core-label {
      margin: 0 0 8px 0;
      font-size: var(--desktop-caption);
      font-family: var(--monospace);
      font-weight: 600;
      color: rgba(255,255,255,0.55);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .core-emoji {
      font-size: 13px;
      line-height: 1;
    }
    .core-body {
      margin: 0;
      font-size: var(--desktop-body-sm);
      line-height: 1.7;
      color: #d0d0d0;
    }

    /* CTA */
    .article-cta {
      display: flex;
      align-items: center;
      gap: var(--spacing-03);
      flex-wrap: wrap;
    }
    .btn-read {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 20px;
      background: var(--accent);
      color: var(--background-high-contrast);
      text-decoration: none;
      font-weight: 600;
      font-size: var(--desktop-body-sm);
      border-radius: 6px;
      transition: filter 0.15s;
    }
    .btn-read:hover { filter: brightness(1.1); }
    .btn-disabled {
      opacity: 0.4;
      cursor: not-allowed;
      pointer-events: none;
    }

    /* Share */
    .article-share {
      display: flex;
      align-items: center;
      gap: var(--spacing-04);
      padding-top: var(--spacing-05);
      border-top: 0.5px solid rgba(255,255,255,0.08);
    }
    .share-label {
      font-size: var(--desktop-caption);
