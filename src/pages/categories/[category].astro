---
import Layout from "../../layouts/Layout.astro";

import "@new-ui/foundations";
import Dashboard from "../../components/Dashboard";
import data from "../../data/articles.json";

export function getStaticPaths() {
  // Derive paths from data instead of hardcoding
  return data.articles.map((cat: any) => ({
    params: { category: cat.category }
  }));
}

const { category } = Astro.params;
---

<Layout
  site={`Xarticl.es - ${category}`}
  title="Xarticl.es"
  tagline="A curated directory of the best long-form articles on X."
  pageTitle={`Best ${category.charAt(0).toUpperCase() + category.slice(1)} Articles on X – Curated Articles | Xarticl.es`}
  pageDescription={`Explore the best ${category.charAt(0).toUpperCase() + category.slice(1)} articles from X (Twitter). This page curates high-quality articles about ${category}.`}
  showSearch={true}
>
  <main id="main-content">
    <Dashboard client:load category={category} />
  </main>
</Layout>

